{
  "name": "decagrammaton",
  "version": "0.2.0",
  "type": "module",
  "description": "A reactive UI framework with single-file components",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./internal": {
      "types": "./dist/compiler/script.d.ts",
      "import": "./dist/compiler/script.js"
    },
    "./deca": {
      "types": "./dist/deca.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "ark-of-atrahasis": "^0.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "alien-signals": "^3.2.1",
    "ses": "^2.2.0"
  }
}
